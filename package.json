{
  "name": "crowdfundx",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "compile": "forge build",
    "test": "forge test",
    "deploy": "forge script script/DeployCrowdfunding.s.sol:DeployCrowdfunding --rpc-url $ARC_RPC_URL --private-key $PRIVATE_KEY --broadcast",
    "build": "mkdir -p public && cp -R frontend/. public/",
    "dev": "npx http-server frontend -c-1",
    "start": "npx http-server frontend -c-1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^3.0.0",
    "dotenv": "^16.3.1",
    "hardhat": "^2.18.3",
    "http-server": "^14.1.1"
  }
}
